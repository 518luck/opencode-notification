{
  // 总开关，false 时禁用所有通知
  "enabled": true,
  // 桌面弹窗通知（使用 notify-send）
  "desktop": {
    "enabled": true,
    // 是否显示左侧大图
    "showImage": true,
    // 图片随机权重衰减因子（0~1，越小衰减越快，仅在 image 传文件夹时生效）
    "imageDecayFactor": 0.7,
    // 应用名称（显示在系统通知中心）
    "appName": "OpenCode"
  },
  // TUI 内部 Toast 提示
  "toast": {
    "enabled": true,
    // 样式：info / success / error
    "variant": "info"
  },
  // 语音铃声通知 
  "voice": {
    "enabled": true,
    // 模式：custom=自定义铃声 / default=系统铃声
    "mode": "custom",
    // 首选音频播放器：pw-play / paplay / aplay / ffplay；找不到时会自动回退并记住成功的播放器
    "player": "pw-play",
    // 每次播放后权重衰减系数（0~1，越小衰减越快）
    "decayFactor": 0.7,
    // 系统默认铃声
    "defaultBell": {
      "enabled": false
    },
    // 自定义铃声（从 assets/sound 目录随机播放）
    "customVoice": {
      "enabled": true,
      // 铃声目录名（相对于插件所在目录）
      "musicsDir": "assets/sound"
    }
  },
  // 按事件类型单独配置
  // enabled: 是否通知
  // icon: 自定义小图标（支持三种写法，见下方示例）
  // image: 自定义大图（支持三种写法，见下方示例）
  //
  // icon/image 的值支持三种写法：
  //   1. 单文件路径："assets/icons/permission.svg" 或 "/home/user/pic.jpg"
  //   2. 文件夹路径："assets/icons/permission/" （随机展示，带权重衰减）
  //   3. 不填：使用默认映射（assets/icons/{name}.svg）
  "events": {
    // 需要权限确认时通知
    "permission.asked": {
      "enabled": true,
      "image": "assets/pictures/climax/"
    },
    // 兼容旧版 SDK 的权限事件名
    "permission.updated": {
      "enabled": true,
      "image": "assets/pictures/climax/"
    },
    // OpenCode/agent 需要你回答问题时通知
    "question.asked": {
      "enabled": true,
      "image": "assets/pictures/climax/"
    },
    // 回答结束等待输入时通知
    "session.idle": {
      "enabled": true,
      "image": "assets/pictures/climax/"
    },
    // 会话出错时通知
    "session.error": {
      "enabled": true,
      "image": "assets/pictures/climax/"
    }
  }
}
