{
  // 总开关，false 时禁用所有通知
  "enabled": true,
  // 桌面弹窗通知（使用 notify-send）
  "desktop": {
    "enabled": true,
    // 是否显示左侧大图
    "showImage": true
  },
  // TUI 内部 Toast 提示
  "toast": {
    "enabled": true,
    // 样式：info / success / error
    "variant": "info"
  },
  // 语音铃声通知 
  "voice": {
    "enabled": true,
    // 模式：custom=自定义铃声 / default=系统铃声
    "mode": "custom",
    // 音频播放器：paplay / aplay / ffplay
    "player": "paplay",
    // 每次播放后权重衰减系数（0~1，越小衰减越快）
    "decayFactor": 0.7,
    // 系统默认铃声
    "defaultBell": {
      "enabled": false
    },
    // 自定义铃声（从 assets/sound 目录随机播放）
    "customVoice": {
      "enabled": true,
      // 铃声目录名（相对于插件所在目录）
      "musicsDir": "assets/sound"
    }
  },
  // 按事件类型单独配置
  // enabled: 是否通知
  // icon: 自定义小图标路径（可选，不填则用默认映射 assets/icons/{name}.svg）
  // image: 自定义大图路径（可选，不填则同 icon）
  "events": {
    // 需要权限确认时通知
    "permission.asked": {
      "enabled": true
    },
    // 兼容旧版 SDK 的权限事件名
    "permission.updated": {
      "enabled": true
    },
    // OpenCode/agent 需要你回答问题时通知
    "question.asked": {
      "enabled": true
    },
    // 回答结束等待输入时通知
    "session.idle": {
      "enabled": true
    },
    // 会话出错时通知
    "session.error": {
      "enabled": true
    }
  }
}
