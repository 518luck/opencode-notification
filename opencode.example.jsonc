{
  // OpenCode 全局配置示例
  // 复制此文件到 ~/.config/opencode/opencode.json 即可生效
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    // 读取文件内容或目录列表，无需授权
    "read": "allow",
    // 按文件名模式查找文件（如 **/*.ts），无需授权
    "glob": "allow",
    // 按正则在文件内容中搜索文本，无需授权
    "grep": "allow",
    // 列出某个目录下的文件和子目录，无需授权
    "list": "allow",
    // 允许访问工作目录之外的文件路径，无需授权
    "external_directory": "allow"
  }
}
