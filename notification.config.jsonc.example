{
  // 总开关，false 时禁用所有通知
  "enabled": true,
  // 桌面弹窗通知（使用 notify-send）
  "desktop": {
    "enabled": true,
    // 是否显示左侧大图
    "showImage": true,
    // 图片随机权重衰减因子（0~1，越小衰减越快，仅在 image 传文件夹时生效）
    "imageDecayFactor": 0.7,
    // 应用名称（显示在系统通知中心）
    "appName": "OpenCode"
  },
  // TUI 内部 Toast 提示
  "toast": {
    "enabled": true,
    // 样式：info / success / error
    "variant": "info"
  },
  // 语音铃声通知
  "voice": {
    "enabled": true,
    // 首选音频播放器：pw-play / paplay / aplay / ffplay；找不到时会自动回退并记住成功的播放器
    "player": "pw-play",
    // 事件语音目录的权重衰减系数（0~1，越小衰减越快）
    "decayFactor": 0.7
  },
  // 按事件类型单独配置
  // enabled: 是否通知
  // icon: 自定义小图标（支持三种写法，见下方示例）
  // image: 自定义大图（支持三种写法，见下方示例）
  // voice: 自定义语音（支持单文件/文件夹；不填或无效则播放系统默认铃声）
  //
  // icon/image 的值支持三种写法：
  //   1. 单文件路径："assets/icons/permission.svg" 或 "/home/user/pic.jpg"
  //   2. 文件夹路径："assets/icons/permission/" （随机展示，带权重衰减）
  //   3. 不填：使用默认映射（assets/icons/{name}.svg）
  //
  // voice 的值支持三种写法：
  //   1. 单音频文件路径："assets/sound/session-idle/default.mp3"
  //   2. 文件夹路径："assets/sound/session-idle/" （随机播放，带权重衰减）
  //   3. 不填或路径无效：播放系统默认铃声
  "events": {
    // 需要权限确认时通知
    "permission.asked": {
      "enabled": true,
      "image": "assets/pictures/climax/",
      "voice": "assets/sound/permission/"
    },
    // 兼容旧版 SDK 的权限事件名
    "permission.updated": {
      "enabled": true,
      "image": "assets/pictures/climax/",
      "voice": "assets/sound/permission/"
    },
    // OpenCode/agent 需要你回答问题时通知
    "question.asked": {
      "enabled": true,
      "image": "assets/pictures/climax/",
      "voice": "assets/sound/question/"
    },
    // 回答结束等待输入时通知
    "session.idle": {
      "enabled": true,
      "image": "assets/pictures/climax/",
      "voice": "assets/sound/session-idle/"
    },
    // 会话出错时通知
    "session.error": {
      "enabled": true,
      "image": "assets/pictures/climax/",
      "voice": "assets/sound/session-error/"
    }
  }
}
