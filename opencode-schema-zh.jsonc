{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$ref": "#/$defs/Config", // $ref = 引用另一段 schema 定义  # = 当前这个 JSON 文档  /$defs/Config = 当前文档里的 $defs.Config
  "$defs": {
    "LogLevel": { //日志默认位置 macOS/Linux: ~/.local/share/opencode/log/   Windows: %USERPROFILE%\.local\share\opencode\log
      "type": "string",
      "enum": [
        "DEBUG",
        "INFO",
        "WARN",
        "ERROR"
      ],
      "description": "日志级别"
    },
    "ServerConfig": { // opencode serve 和 opencode web 这类启动本地服务的场景用。
      "type": "object",
      "properties": {
        "port": {
          "exclusiveMinimum": 0,
          "type": "integer",
          "maximum": 9007199254740991,
          "description": "监听端口"
        },
        "hostname": {
          "type": "string",
          "description": "监听主机名"
        },
        "mdns": {
          "type": "boolean",
          "description": "启用 mDNS 服务发现"
        },
        "mdnsDomain": {
          "type": "string",
          "description": "自定义 mDNS 服务域名（默认：opencode.local）"
        },
        "cors": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "额外允许的 CORS 域名"
        }
      },
      "additionalProperties": false //$schema server 里只能写这里列出来的字段，不能乱加别的字段。
    },
    "ReferenceConfigEntry": { //定义 reference 配置里每个别名条目允许的写法。
      //reference
      // - 你先在配置里定义一个名字
      // - 这个名字指向一个 Git 仓库，或者一个本地目录
      // - 之后在对话里就能用 @alias 或 @alias/path 引用它
      "anyOf": [ //满足下面任意一种格式都可以。
        {
          "type": "string"
        },
        {
          "type": "object",
          "properties": { //定义一个对象里有哪些字段，以及每个字段各自的规则。
            "repository": { //仓库地址、GitHub 简写、或者 host/path
              "type": "string",
              "description": "Git 仓库 URL、host/path 引用，或 GitHub owner/repo 简写"
            },
            "branch": { //要检查的分支或 ref
              "type": "string",
              "description": "Scout 需要克隆和检查的分支或 ref"
            }
          },
          "required": [
            "repository" // 必填
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "path": {
              "type": "string",
              "description": "本地参考目录的绝对路径、~/ 路径，或相对工作区路径"
            }
          },
          "required": [
            "path"
          ],
          "additionalProperties": false
        }
      ]
    },
    "ReferenceConfig": { //reference 本身是一个对象，并且这个对象里的每个字段值，都必须符合 ReferenceConfigEntry这套规则。
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/ReferenceConfigEntry"
      }
    },
    "PermissionActionConfig": { //定义一个“权限动作”的可选值。 的作用是定义“一个单独的权限决定”能写什么：
      "type": "string",
      "enum": [
        "ask", //：先询问
        "allow", //：允许
        "deny" //：拒绝
      ]
    },
    "PermissionObjectConfig": { // 的作用是定义“一个规则对象”该怎么写：
      "type": "object",
      "additionalProperties": {
        //例如
        // {
        //   "src/**": "allow",
        //   ".env": "deny"
        // }
        "$ref": "#/$defs/PermissionActionConfig"
      }
    },
    "PermissionRuleConfig": {
      "anyOf": [
        {
          "$ref": "#/$defs/PermissionActionConfig"
        },
        {
          "$ref": "#/$defs/PermissionObjectConfig"
        }
      ]
    },
    "PermissionConfig": {
      "anyOf": [
        {
          "$ref": "#/$defs/PermissionActionConfig"
        },
        {
          "type": "object",
          "properties": {
            "read": {
              "$ref": "#/$defs/PermissionRuleConfig"
            },
            "edit": {
              "$ref": "#/$defs/PermissionRuleConfig"
            },
            "glob": {
              "$ref": "#/$defs/PermissionRuleConfig"
            },
            "grep": {
              "$ref": "#/$defs/PermissionRuleConfig"
            },
            "list": {
              "$ref": "#/$defs/PermissionRuleConfig"
            },
            "bash": {
              "$ref": "#/$defs/PermissionRuleConfig"
            },
            "task": {
              "$ref": "#/$defs/PermissionRuleConfig"
            },
            "external_directory": {
              "$ref": "#/$defs/PermissionRuleConfig"
            },
            "todowrite": {
              "$ref": "#/$defs/PermissionActionConfig"
            },
            "question": {
              "$ref": "#/$defs/PermissionActionConfig"
            },
            "webfetch": {
              "$ref": "#/$defs/PermissionActionConfig"
            },
            "websearch": {
              "$ref": "#/$defs/PermissionActionConfig"
            },
            "repo_clone": {
              "$ref": "#/$defs/PermissionRuleConfig"
            },
            "repo_overview": {
              "$ref": "#/$defs/PermissionRuleConfig"
            },
            "lsp": {
              "$ref": "#/$defs/PermissionRuleConfig"
            },
            "doom_loop": {
              "$ref": "#/$defs/PermissionActionConfig"
            },
            "skill": {
              "$ref": "#/$defs/PermissionRuleConfig"
            }
          },
          "additionalProperties": {
            "$ref": "#/$defs/PermissionRuleConfig"
          }
        }
      ]
    },
    "AgentConfig": {
      "type": "object",
      "properties": {
        "model": {
          "type": "string",
          "$ref": "https://models.dev/model-schema.json#/$defs/Model"
        },
        "variant": {
          "type": "string",
          "description": "该 agent 的默认模型变体（仅在使用该 agent 配置的模型时生效）"
        },
        "temperature": {
          "type": "number"
        },
        "top_p": {
          "type": "number"
        },
        "prompt": {
          "type": "string"
        },
        "tools": {
          "type": "object",
          "additionalProperties": {
            "type": "boolean"
          },
          "description": "@deprecated 请改用 'permission' 字段"
        },
        "disable": {
          "type": "boolean"
        },
        "description": {
          "type": "string",
          "description": "描述该 agent 适合在什么场景下使用"
        },
        "mode": {
          "type": "string",
          "enum": [
            "subagent",
            "primary",
            "all"
          ]
        },
        "hidden": {
          "type": "boolean",
          "description": "在 @ 自动补全菜单中隐藏此 subagent（默认：false，仅适用于 mode: subagent）"
        },
        "options": {
          "type": "object"
        },
        "color": {
          "anyOf": [
            {
              "pattern": "^#[0-9a-fA-F]{6}$",
              "type": "string"
            },
            {
              "type": "string",
              "enum": [
                "primary",
                "secondary",
                "accent",
                "success",
                "warning",
                "error",
                "info"
              ]
            }
          ],
          "description": "十六进制颜色值（例如 #FF5733）或主题颜色（例如 primary）"
        },
        "steps": {
          "exclusiveMinimum": 0,
          "type": "integer",
          "maximum": 9007199254740991,
          "description": "在强制改为纯文本响应之前，允许的最大 agent 迭代次数"
        },
        "maxSteps": {
          "exclusiveMinimum": 0,
          "type": "integer",
          "maximum": 9007199254740991,
          "description": "@deprecated 请改用 'steps' 字段"
        },
        "permission": {
          "$ref": "#/$defs/PermissionConfig"
        }
      }
    },
    "ProviderConfig": {
      "type": "object",
      "properties": {
        "api": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "env": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "id": {
          "type": "string"
        },
        "npm": {
          "type": "string"
        },
        "whitelist": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "blacklist": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "options": {
          "type": "object",
          "properties": {
            "apiKey": {
              "type": "string"
            },
            "baseURL": {
              "type": "string"
            },
            "enterpriseUrl": {
              "type": "string",
              "description": "用于 Copilot 认证的 GitHub Enterprise URL"
            },
            "setCacheKey": {
              "type": "boolean",
              "description": "为该 provider 启用 promptCacheKey（默认 false）"
            },
            "timeout": {
              "anyOf": [
                {
                  "exclusiveMinimum": 0,
                  "type": "integer",
                  "maximum": 9007199254740991
                },
                {
                  "type": "boolean",
                  "enum": [
                    false
                  ]
                }
              ],
              "description": "该 provider 请求的超时时间（毫秒）。默认 300000（5 分钟）。设为 false 可禁用超时。"
            },
            "chunkTimeout": {
              "exclusiveMinimum": 0,
              "type": "integer",
              "maximum": 9007199254740991,
              "description": "流式 SSE 分块之间的超时时间（毫秒）。若在该时间窗口内未收到新分块，请求将被中止。"
            }
          }
        },
        "models": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "name": {
                "type": "string"
              },
              "family": {
                "type": "string"
              },
              "release_date": {
                "type": "string"
              },
              "attachment": {
                "type": "boolean"
              },
              "reasoning": {
                "type": "boolean"
              },
              "temperature": {
                "type": "boolean"
              },
              "tool_call": {
                "type": "boolean"
              },
              "interleaved": {
                "anyOf": [
                  {
                    "type": "boolean",
                    "enum": [
                      true
                    ]
                  },
                  {
                    "type": "object",
                    "properties": {
                      "field": {
                        "type": "string",
                        "enum": [
                          "reasoning_content",
                          "reasoning_details"
                        ]
                      }
                    },
                    "required": [
                      "field"
                    ],
                    "additionalProperties": false
                  }
                ]
              },
              "cost": {
                "type": "object",
                "properties": {
                  "input": {
                    "type": "number"
                  },
                  "output": {
                    "type": "number"
                  },
                  "cache_read": {
                    "type": "number"
                  },
                  "cache_write": {
                    "type": "number"
                  },
                  "context_over_200k": {
                    "type": "object",
                    "properties": {
                      "input": {
                        "type": "number"
                      },
                      "output": {
                        "type": "number"
                      },
                      "cache_read": {
                        "type": "number"
                      },
                      "cache_write": {
                        "type": "number"
                      }
                    },
                    "required": [
                      "input",
                      "output"
                    ],
                    "additionalProperties": false
                  }
                },
                "required": [
                  "input",
                  "output"
                ],
                "additionalProperties": false
              },
              "limit": {
                "type": "object",
                "properties": {
                  "context": {
                    "type": "number"
                  },
                  "input": {
                    "type": "number"
                  },
                  "output": {
                    "type": "number"
                  }
                },
                "required": [
                  "context",
                  "output"
                ],
                "additionalProperties": false
              },
              "modalities": {
                "type": "object",
                "properties": {
                  "input": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "enum": [
                        "text",
                        "audio",
                        "image",
                        "video",
                        "pdf"
                      ]
                    }
                  },
                  "output": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "enum": [
                        "text",
                        "audio",
                        "image",
                        "video",
                        "pdf"
                      ]
                    }
                  }
                },
                "required": [
                  "input",
                  "output"
                ],
                "additionalProperties": false
              },
              "experimental": {
                "type": "boolean"
              },
              "status": {
                "type": "string",
                "enum": [
                  "alpha",
                  "beta",
                  "deprecated",
                  "active"
                ]
              },
              "provider": {
                "type": "object",
                "properties": {
                  "npm": {
                    "type": "string"
                  },
                  "api": {
                    "type": "string"
                  }
                },
                "additionalProperties": false
              },
              "options": {
                "type": "object"
              },
              "headers": {
                "type": "object",
                "additionalProperties": {
                  "type": "string"
                }
              },
              "variants": {
                "type": "object",
                "additionalProperties": {
                  "type": "object",
                  "properties": {
                    "disabled": {
                      "type": "boolean",
                      "description": "禁用该模型的此变体"
                    }
                  }
                },
                "description": "变体级配置"
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "McpLocalConfig": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "local"
          ],
          "description": "MCP 服务器连接类型"
        },
        "command": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "运行 MCP 服务器的命令及参数"
        },
        "environment": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          },
          "description": "运行 MCP 服务器时设置的环境变量"
        },
        "enabled": {
          "type": "boolean",
          "description": "是否在启动时启用该 MCP 服务器"
        },
        "timeout": {
          "exclusiveMinimum": 0,
          "type": "integer",
          "maximum": 9007199254740991,
          "description": "MCP 服务器请求超时时间（毫秒）。如未指定，默认 5000（5 秒）。"
        }
      },
      "required": [
        "type",
        "command"
      ],
      "additionalProperties": false
    },
    "McpOAuthConfig": {
      "type": "object",
      "properties": {
        "clientId": {
          "type": "string",
          "description": "OAuth 客户端 ID。若未提供，将尝试动态客户端注册（RFC 7591）。"
        },
        "clientSecret": {
          "type": "string",
          "description": "OAuth 客户端密钥（如果授权服务器要求）"
        },
        "scope": {
          "type": "string",
          "description": "授权时请求的 OAuth scopes"
        },
        "redirectUri": {
          "type": "string",
          "description": "OAuth 回调地址（默认：http://127.0.0.1:19876/mcp/oauth/callback）"
        }
      },
      "additionalProperties": false
    },
    "McpRemoteConfig": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "remote"
          ],
          "description": "MCP 服务器连接类型"
        },
        "url": {
          "type": "string",
          "description": "远程 MCP 服务器的 URL"
        },
        "enabled": {
          "type": "boolean",
          "description": "是否在启动时启用该 MCP 服务器"
        },
        "headers": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          },
          "description": "请求时要发送的请求头"
        },
        "oauth": {
          "anyOf": [
            {
              "$ref": "#/$defs/McpOAuthConfig"
            },
            {
              "type": "boolean",
              "enum": [
                false
              ]
            }
          ],
          "description": "MCP 服务器的 OAuth 认证配置。设为 false 可禁用 OAuth 自动检测。"
        },
        "timeout": {
          "exclusiveMinimum": 0,
          "type": "integer",
          "maximum": 9007199254740991,
          "description": "MCP 服务器请求超时时间（毫秒）。如未指定，默认 5000（5 秒）。"
        }
      },
      "required": [
        "type",
        "url"
      ],
      "additionalProperties": false
    },
    "LayoutConfig": {
      "type": "string",
      "enum": [
        "auto",
        "stretch"
      ]
    },
    "ImageAttachmentConfig": {
      "type": "object",
      "properties": {
        "auto_resize": {
          "type": "boolean",
          "description": "当图片超过配置限制时，在发送给模型前自动缩放（默认：true）"
        },
        "max_width": {
          "exclusiveMinimum": 0,
          "type": "integer",
          "maximum": 9007199254740991,
          "description": "图片在缩放或拒绝附加前允许的最大宽度（默认：2000）"
        },
        "max_height": {
          "exclusiveMinimum": 0,
          "type": "integer",
          "maximum": 9007199254740991,
          "description": "图片在缩放或拒绝附加前允许的最大高度（默认：2000）"
        },
        "max_base64_bytes": {
          "exclusiveMinimum": 0,
          "type": "integer",
          "maximum": 9007199254740991,
          "description": "图片附件允许的最大 base64 负载字节数（默认：4718592）"
        }
      },
      "additionalProperties": false
    },
    "AttachmentConfig": {
      "type": "object",
      "properties": {
        "image": {
          "$ref": "#/$defs/ImageAttachmentConfig",
          "description": "图片附件配置"
        }
      },
      "additionalProperties": false
    },
    "Config": {
      "type": "object",
      "properties": {
        "$schema": {
          "type": "string",
          "description": "用于配置校验的 JSON Schema 引用"
        },
        "shell": {
          "type": "string",
          "description": "终端和 bash 工具默认使用的 shell"
        },
        "logLevel": {
          "$ref": "#/$defs/LogLevel",
          "description": "日志级别"
        },
        "server": {
          "$ref": "#/$defs/ServerConfig",
          "description": "用于 opencode serve 和 web 命令的服务器配置"
        },
        "command": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "template": {
                "type": "string"
              },
              "description": {
                "type": "string"
              },
              "agent": {
                "type": "string"
              },
              "model": {
                "type": "string",
                "$ref": "https://models.dev/model-schema.json#/$defs/Model"
              },
              "subtask": {
                "type": "boolean"
              }
            },
            "required": [
              "template"
            ],
            "additionalProperties": false
          },
          "description": "命令配置，见 https://opencode.ai/docs/commands"
        },
        "skills": {
          "type": "object",
          "properties": {
            "paths": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "额外的技能目录路径"
            },
            "urls": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "拉取技能的 URL（例如 https://example.com/.well-known/skills/）"
            }
          },
          "additionalProperties": false,
          "description": "附加技能目录路径配置"
        },
        "reference": {
          "$ref": "#/$defs/ReferenceConfig",
          "description": "具名的 Git 或本地目录引用，可通过 @alias 或 @alias/path 提及"
        },
        "watcher": {
          "type": "object",
          "properties": {
            "ignore": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "additionalProperties": false
        },
        "snapshot": {
          "type": "boolean",
          "description": "启用或禁用快照追踪。为 false 时不会记录文件系统快照，undo/revert 也无法撤销或重做文件变更。默认 true。"
        },
        "plugin": {
          "type": "array",
          "items": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "array",
                "prefixItems": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "object"
                  }
                ],
                "maxItems": 2,
                "minItems": 2
              }
            ]
          }
        },
        "share": {
          "type": "string",
          "enum": [
            "manual",
            "auto",
            "disabled"
          ],
          "description": "控制分享行为：'manual' 允许手动分享，'auto' 自动分享，'disabled' 完全禁用分享"
        },
        "autoshare": {
          "type": "boolean",
          "description": "@deprecated 请改用 'share' 字段。自动分享新创建的会话"
        },
        "autoupdate": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "string",
              "enum": [
                "notify"
              ]
            }
          ],
          "description": "自动更新到最新版本。设为 true 自动更新，false 禁用，或 'notify' 仅显示更新通知"
        },
        "disabled_providers": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "禁用那些会被自动加载的 provider"
        },
        "enabled_providers": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "设置后，仅启用这些 provider，其他 provider 会被忽略"
        },
        "model": {
          "type": "string",
          "description": "使用的模型，格式为 provider/model，例如 anthropic/claude-2",
          "$ref": "https://models.dev/model-schema.json#/$defs/Model"
        },
        "small_model": {
          "type": "string",
          "description": "用于标题生成等任务的小模型，格式为 provider/model",
          "$ref": "https://models.dev/model-schema.json#/$defs/Model"
        },
        "default_agent": {
          "type": "string",
          "description": "未显式指定时使用的默认 agent。必须是 primary agent。若未设置或无效，则回退到 'build'。"
        },
        "username": {
          "type": "string",
          "description": "会话中显示的自定义用户名，替代系统用户名"
        },
        "mode": {
          "type": "object",
          "properties": {
            "build": {
              "$ref": "#/$defs/AgentConfig"
            },
            "plan": {
              "$ref": "#/$defs/AgentConfig"
            }
          },
          "additionalProperties": {
            "$ref": "#/$defs/AgentConfig"
          },
          "description": "@deprecated 请改用 `agent` 字段"
        },
        "agent": {
          "type": "object",
          "properties": {
            "plan": {
              "$ref": "#/$defs/AgentConfig"
            },
            "build": {
              "$ref": "#/$defs/AgentConfig"
            },
            "general": {
              "$ref": "#/$defs/AgentConfig"
            },
            "explore": {
              "$ref": "#/$defs/AgentConfig"
            },
            "scout": {
              "$ref": "#/$defs/AgentConfig"
            },
            "title": {
              "$ref": "#/$defs/AgentConfig"
            },
            "summary": {
              "$ref": "#/$defs/AgentConfig"
            },
            "compaction": {
              "$ref": "#/$defs/AgentConfig"
            }
          },
          "additionalProperties": {
            "$ref": "#/$defs/AgentConfig"
          },
          "description": "Agent 配置，见 https://opencode.ai/docs/agents"
        },
        "provider": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/ProviderConfig"
          },
          "description": "自定义 provider 配置及模型覆盖"
        },
        "mcp": {
          "type": "object",
          "additionalProperties": {
            "anyOf": [
              {
                "anyOf": [
                  {
                    "$ref": "#/$defs/McpLocalConfig"
                  },
                  {
                    "$ref": "#/$defs/McpRemoteConfig"
                  }
                ]
              },
              {
                "type": "object",
                "properties": {
                  "enabled": {
                    "type": "boolean"
                  }
                },
                "required": [
                  "enabled"
                ],
                "additionalProperties": false
              }
            ]
          },
          "description": "MCP（Model Context Protocol）服务器配置"
        },
        "formatter": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "object",
              "additionalProperties": {
                "type": "object",
                "properties": {
                  "disabled": {
                    "type": "boolean"
                  },
                  "command": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "environment": {
                    "type": "object",
                    "additionalProperties": {
                      "type": "string"
                    }
                  },
                  "extensions": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                },
                "additionalProperties": false
              }
            }
          ],
          "description": "启用或配置格式化器。省略或设为 false 表示禁用，true 表示启用内置配置，对象表示在启用内置配置的基础上进行覆盖。"
        },
        "lsp": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "object",
              "additionalProperties": {
                "anyOf": [
                  {
                    "type": "object",
                    "properties": {
                      "disabled": {
                        "type": "boolean",
                        "enum": [
                          true
                        ]
                      }
                    },
                    "required": [
                      "disabled"
                    ],
                    "additionalProperties": false
                  },
                  {
                    "type": "object",
                    "properties": {
                      "command": {
                        "type": "array",
                        "items": {
                          "type": "string"
                        }
                      },
                      "extensions": {
                        "type": "array",
                        "items": {
                          "type": "string"
                        }
                      },
                      "disabled": {
                        "type": "boolean"
                      },
                      "env": {
                        "type": "object",
                        "additionalProperties": {
                          "type": "string"
                        }
                      },
                      "initialization": {
                        "type": "object"
                      }
                    },
                    "required": [
                      "command"
                    ],
                    "additionalProperties": false
                  }
                ]
              }
            }
          ],
          "description": "启用或配置 LSP 服务器。省略或设为 false 表示禁用，true 表示启用内置配置，对象表示在启用内置配置的基础上进行覆盖。"
        },
        "instructions": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "额外引入的 instruction 文件或匹配模式"
        },
        "layout": {
          "$ref": "#/$defs/LayoutConfig",
          "description": "@deprecated 现在始终使用 stretch 布局"
        },
        "permission": {
          "$ref": "#/$defs/PermissionConfig"
        },
        "tools": {
          "type": "object",
          "additionalProperties": {
            "type": "boolean"
          }
        },
        "attachment": {
          "$ref": "#/$defs/AttachmentConfig",
          "description": "附件处理配置，包括图片尺寸限制和缩放行为"
        },
        "enterprise": {
          "type": "object",
          "properties": {
            "url": {
              "type": "string",
              "description": "企业版 URL"
            }
          },
          "additionalProperties": false
        },
        "tool_output": {
          "type": "object",
          "properties": {
            "max_lines": {
              "exclusiveMinimum": 0,
              "type": "integer",
              "maximum": 9007199254740991,
              "description": "工具输出在被截断并写入磁盘前允许的最大行数（默认：2000）"
            },
            "max_bytes": {
              "exclusiveMinimum": 0,
              "type": "integer",
              "maximum": 9007199254740991,
              "description": "工具输出在被截断并写入磁盘前允许的最大字节数（默认：51200）"
            }
          },
          "additionalProperties": false,
          "description": "工具输出截断阈值。超过任一限制时，完整文本会写入截断目录，并返回一段预览。"
        },
        "compaction": {
          "type": "object",
          "properties": {
            "auto": {
              "type": "boolean",
              "description": "当上下文已满时自动执行压缩（默认：true）"
            },
            "prune": {
              "type": "boolean",
              "description": "启用旧工具输出清理（默认：true）"
            },
            "tail_turns": {
              "minimum": 0,
              "type": "integer",
              "maximum": 9007199254740991,
              "description": "压缩时按原文保留的最近用户轮次数量，包含其后的 assistant/tool 响应（默认：2）"
            },
            "preserve_recent_tokens": {
              "minimum": 0,
              "type": "integer",
              "maximum": 9007199254740991,
              "description": "压缩后按原文保留的最近轮次最大 token 数"
            },
            "reserved": {
              "minimum": 0,
              "type": "integer",
              "maximum": 9007199254740991,
              "description": "为压缩预留的 token 缓冲区，用于避免压缩过程中窗口溢出"
            }
          },
          "additionalProperties": false
        },
        "experimental": {
          "type": "object",
          "properties": {
            "disable_paste_summary": {
              "type": "boolean"
            },
            "batch_tool": {
              "type": "boolean",
              "description": "启用 batch tool"
            },
            "openTelemetry": {
              "type": "boolean",
              "description": "为 AI SDK 调用启用 OpenTelemetry spans（使用 'experimental_telemetry' 标志）"
            },
            "primary_tools": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "仅对 primary agents 可用的工具"
            },
            "continue_loop_on_deny": {
              "type": "boolean",
              "description": "当工具调用被拒绝时继续 agent 循环"
            },
            "mcp_timeout": {
              "exclusiveMinimum": 0,
              "type": "integer",
              "maximum": 9007199254740991,
              "description": "模型上下文协议（MCP）请求的超时时间（毫秒）"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "allowComments": true,
  "allowTrailingCommas": true
}