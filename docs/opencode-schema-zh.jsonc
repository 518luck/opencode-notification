{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$ref": "#/$defs/Config", // $ref = 引用另一段 schema 定义  # = 当前这个 JSON 文档  /$defs/Config = 当前文档里的 $defs.Config
  "$defs": {
    "LogLevel": { //日志默认位置 macOS/Linux: ~/.local/share/opencode/log/   Windows: %USERPROFILE%\.local\share\opencode\log
      "type": "string",
      "enum": [
        "DEBUG",
        "INFO",
        "WARN",
        "ERROR"
      ],
      "description": "日志级别"
    },
    "ServerConfig": { // opencode serve 和 opencode web 这类启动本地服务的场景用。
      "type": "object",
      "properties": {
        "port": {
          "exclusiveMinimum": 0,
          "type": "integer",
          "maximum": 9007199254740991,
          "description": "监听端口"
        },
        "hostname": {
          "type": "string",
          "description": "监听主机名"
        },
        "mdns": {
          "type": "boolean",
          "description": "启用 mDNS 服务发现"
        },
        "mdnsDomain": {
          "type": "string",
          "description": "自定义 mDNS 服务域名（默认：opencode.local）"
        },
        "cors": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "额外允许的 CORS 域名"
        }
      },
      "additionalProperties": false //$schema server 里只能写这里列出来的字段，不能乱加别的字段。
    },
    "ReferenceConfigEntry": { //定义 reference 配置里每个别名条目允许的写法。
      //reference
      // - 你先在配置里定义一个名字
      // - 这个名字指向一个 Git 仓库，或者一个本地目录
      // - 之后在对话里就能用 @alias 或 @alias/path 引用它
      "anyOf": [ //满足下面任意一种格式都可以。
        {
          "type": "string"
        },
        {
          "type": "object",
          "properties": { //定义一个对象里有哪些字段，以及每个字段各自的规则。
            "repository": { //仓库地址、GitHub 简写、或者 host/path
              "type": "string",
              "description": "Git 仓库 URL、host/path 引用，或 GitHub owner/repo 简写"
            },
            "branch": { //要检查的分支或 ref
              "type": "string",
              "description": "Scout 需要克隆和检查的分支或 ref"
            }
          },
          "required": [
            "repository" // 必填
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "path": {
              "type": "string",
              "description": "本地参考目录的绝对路径、~/ 路径，或相对工作区路径"
            }
          },
          "required": [
            "path"
          ],
          "additionalProperties": false
        }
      ]
    },
    "ReferenceConfig": { //reference 本身是一个对象，并且这个对象里的每个字段值，都必须符合 ReferenceConfigEntry这套规则。
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/ReferenceConfigEntry"
      }
    },
    "PermissionActionConfig": { //定义一个“权限动作”的可选值。 的作用是定义“一个单独的权限决定”能写什么：
      "type": "string",
      "enum": [
        "ask", //：先询问
        "allow", //：允许
        "deny" //：拒绝
      ]
    },
    "PermissionObjectConfig": { // 的作用是定义“一个规则对象”该怎么写：
      "type": "object",
      "additionalProperties": {
        //例如
        // {
        //   "app/**": "allow",
        //   ".env": "deny"
        // }
        "$ref": "#/$defs/PermissionActionConfig"
      }
    },
    "PermissionRuleConfig": {
      "anyOf": [
        {
          "$ref": "#/$defs/PermissionActionConfig"
        },
        {
          "$ref": "#/$defs/PermissionObjectConfig"
        }
      ]
    },
    "PermissionConfig": {
      "anyOf": [
        {
          "$ref": "#/$defs/PermissionActionConfig"
        },
        {
          "type": "object",
          "properties": {
            "read": {
              "$ref": "#/$defs/PermissionRuleConfig"
            },
            "edit": {
              "$ref": "#/$defs/PermissionRuleConfig"
            },
            "glob": {
              "$ref": "#/$defs/PermissionRuleConfig"
            },
            "grep": {
              "$ref": "#/$defs/PermissionRuleConfig"
            },
            "list": {
              "$ref": "#/$defs/PermissionRuleConfig"
            },
            "bash": {
              "$ref": "#/$defs/PermissionRuleConfig"
            },
            "task": {
              "$ref": "#/$defs/PermissionRuleConfig"
            },
            "external_directory": {
              "$ref": "#/$defs/PermissionRuleConfig"
            },
            "todowrite": {
              "$ref": "#/$defs/PermissionActionConfig"
            },
            "question": {
              "$ref": "#/$defs/PermissionActionConfig"
            },
            "webfetch": {
              "$ref": "#/$defs/PermissionActionConfig"
            },
            "websearch": {
              "$ref": "#/$defs/PermissionActionConfig"
            },
            "repo_clone": {
              "$ref": "#/$defs/PermissionRuleConfig"
            },
            "repo_overview": {
              "$ref": "#/$defs/PermissionRuleConfig"
            },
            "lsp": {
              "$ref": "#/$defs/PermissionRuleConfig"
            },
            "doom_loop": {
              "$ref": "#/$defs/PermissionActionConfig"
            },
            "skill": {
              "$ref": "#/$defs/PermissionRuleConfig"
            }
          },
          "additionalProperties": {
            "$ref": "#/$defs/PermissionRuleConfig"
          }
        }
      ]
    },
    "AgentConfig": { //定义“一个 agent 配置对象”可以写哪些字段。
      /*
          实际写法大概像这样：
          {
            "agent": {
              "reviewer": {
                "description": "只负责代码审查",
                "mode": "subagent",
                "model": "openai/gpt-5",
                "permission": {
                  "edit": "deny",
                  "bash": "ask"
                }
              }
            }
          }
    */
      "type": "object",
      "properties": {
        "model": { // 这个 agent 默认使用哪个模型
          "type": "string",
          "$ref": "https://models.dev/model-schema.json#/$defs/Model"
        },
        "variant": { //该模型默认用哪个变体
          "type": "string",
          "description": "该 agent 的默认模型变体（仅在使用该 agent 配置的模型时生效）"
        },
        "temperature": { //采样温度 控制模型输出随机性/发散度
          "type": "number" //值越低：越稳定、越保守、越一致  值越高：越随机、越发散、越有变化
        },
        "top_p": { //采样参数 top_p  调“模型每一步允许从多大范围的候选词里选”
          "type": "number"
        },
        "prompt": { // 给这个 agent 追加或定制的提示词
          "type": "string"
        },
        "tools": {
          "type": "object",
          "additionalProperties": {
            "type": "boolean"
          },
          "description": "@deprecated 请改用 'permission' 字段"
        },
        "disable": { // 禁用该 agent 的功能
          "type": "boolean"
        },
        "description": { //描述该 agent 适合在什么场景下使用
          "type": "string",
          "description": "描述该 agent 适合在什么场景下使用"
        },
        "mode": { // agent 的工作模式 / agent 类型
          "type": "string",
          "enum": [
            "subagent", //subagent，是主 agent 下面挂载的“插件”或“专家”
            "primary", //主 agent
            "all"
          ]
        },
        "hidden": { //在 @ 自动补全菜单中隐藏此 subagent（默认：false，仅适用于 mode: subagent）
          "type": "boolean", //hidden: true 会把这个 subagent 从 @ 自动补全菜单里隐藏 适合那种“内部辅助 agent”
          "description": "在 @ 自动补全菜单中隐藏此 subagent（默认：false，仅适用于 mode: subagent）"
        },
        "options": { // 一些额外的配置选项，通常与模型或特定功能相关
          "type": "object"
        },
        "color": { // agent 在 UI 中的显示颜色
          "anyOf": [
            {
              "pattern": "^#[0-9a-fA-F]{6}$", //符合这个正则规则
              "type": "string"
            },
            {
              "type": "string",
              "enum": [ //预设名字
                "primary", //主颜色
                "secondary", //次颜色
                "accent", //强调颜色
                "success", //成功颜色
                "warning", //警告颜色
                "error", //错误颜色
                "info" //信息颜色
              ]
            }
          ],
          "description": "十六进制颜色值（例如 #FF5733）或主题颜色（例如 primary）"
        },
        "steps": { //一个 agent 最多能连续“自主调用工具并继续思考”多少轮，超过这个次数后，就不再继续跑工具流程，而是直接返回一段普通文字结果。
          "exclusiveMinimum": 0,
          "type": "integer",
          "maximum": 9007199254740991,
          "description": "在强制改为纯文本响应之前，允许的最大 agent 迭代次数"
        },
        "maxSteps": {
          "exclusiveMinimum": 0, //必须大于 0
          "type": "integer",
          "maximum": 9007199254740991,
          "description": "@deprecated 请改用 'steps' 字段"
        },
        "permission": { // 定义 agent 可以执行的操作权限
          "$ref": "#/$defs/PermissionConfig"
        }
      }
    },
    "ProviderConfig": { //定义一个模型提供商（provider）配置对象应该怎么写。
      "type": "object",
      "properties": {
        "api": { //指定这个 provider 使用哪类 API
          "type": "string"
        },
        "name": { // provider 的人类可读名称
          "type": "string"
        },
        "env": { // 依赖哪些环境变量
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "id": { //provider 标识
          "type": "string"
        },
        "npm": { //provider 对应的 npm 包
          "type": "string"
        },
        "whitelist": { //允许的模型列表
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "blacklist": { //禁止的模型列表
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "options": { //模型提供商通用的运行时选项 / 这个 provider 的连接参数
          "type": "object",
          "properties": { //provider 配置的是“服务商怎么连接”。
            "apiKey": { //API 密钥
              "type": "string"
            },
            "baseURL": { //请求基地址
              "type": "string"
            },
            "enterpriseUrl": { //GitHub Enterprise 地址，仅用于 Copilot 认证场景
              "type": "string",
              "description": "用于 Copilot 认证的 GitHub Enterprise URL"
            },
            "setCacheKey": { //是否给这个 provider 启用 promptCacheKey。
              "type": "boolean",
              "description": "为该 provider 启用 promptCacheKey（默认 false）"
            },
            "timeout": { //是整个请求的超时时间，单位是毫秒
              "anyOf": [
                {
                  "exclusiveMinimum": 0,
                  "type": "integer",
                  "maximum": 9007199254740991
                },
                {
                  "type": "boolean",
                  "enum": [
                    false
                  ]
                }
              ],
              "description": "该 provider 请求的超时时间（毫秒）。默认 300000（5 分钟）。设为 false 可禁用超时。"
            },
            "chunkTimeout": { //是流式响应时，两个 SSE 数据块之间允许等待的最长时间，单位也是毫秒。
              "exclusiveMinimum": 0,
              "type": "integer",
              "maximum": 9007199254740991,
              "description": "流式 SSE 分块之间的超时时间（毫秒）。若在该时间窗口内未收到新分块，请求将被中止。"
            }
          }
        },
        "models": { //models 配置的是“这个服务商下面有哪些模型，以及每个模型有什么能力、价格、限制”。
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "id": { //模型真实 ID
                "type": "string"
              },
              "name": { //显示名称
                "type": "string"
              },
              "family": { //模型家族
                "type": "string"
              },
              "release_date": { //发布日期
                "type": "string"
              },
              "attachment": { //支持附件吗
                "type": "boolean"
              },
              "reasoning": { //支持推理吗
                "type": "boolean"
              },
              "temperature": { //是否支持 temperature 参数
                "type": "boolean"
              },
              "tool_call": { //是否支持工具调用
                "type": "boolean"
              },
              "interleaved": { //推理内容是否混在响应里，以及在哪个字段
                "anyOf": [
                  {
                    "type": "boolean",
                    "enum": [
                      true
                    ]
                  },
                  {
                    "type": "object",
                    "properties": {
                      "field": {
                        "type": "string",
                        "enum": [
                          "reasoning_content",
                          "reasoning_details"
                        ]
                      }
                    },
                    "required": [
                      "field"
                    ],
                    "additionalProperties": false
                  }
                ]
              },
              "cost": { //输入/输出/cache 的费用信息
                "type": "object",
                "properties": {
                  "input": {
                    "type": "number"
                  },
                  "output": {
                    "type": "number"
                  },
                  "cache_read": {
                    "type": "number"
                  },
                  "cache_write": {
                    "type": "number"
                  },
                  "context_over_200k": {
                    "type": "object",
                    "properties": {
                      "input": {
                        "type": "number"
                      },
                      "output": {
                        "type": "number"
                      },
                      "cache_read": {
                        "type": "number"
                      },
                      "cache_write": {
                        "type": "number"
                      }
                    },
                    "required": [
                      "input",
                      "output"
                    ],
                    "additionalProperties": false
                  }
                },
                "required": [
                  "input",
                  "output"
                ],
                "additionalProperties": false
              },
              "limit": { //上下文、输入、输出限制
                "type": "object",
                "properties": {
                  "context": {
                    "type": "number"
                  },
                  "input": {
                    "type": "number"
                  },
                  "output": {
                    "type": "number"
                  }
                },
                "required": [
                  "context",
                  "output"
                ],
                "additionalProperties": false
              },
              "modalities": { //支持的输入/输出模态，比如 text/image/audio/pdf
                "type": "object",
                "properties": {
                  "input": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "enum": [
                        "text",
                        "audio",
                        "image",
                        "video",
                        "pdf"
                      ]
                    }
                  },
                  "output": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "enum": [
                        "text",
                        "audio",
                        "image",
                        "video",
                        "pdf"
                      ]
                    }
                  }
                },
                "required": [
                  "input",
                  "output"
                ],
                "additionalProperties": false
              },
              "experimental": { //是否实验性
                "type": "boolean"
              },
              "status": { //状态，alpha / beta / deprecated / active
                "type": "string",
                "enum": [
                  "alpha",
                  "beta",
                  "deprecated",
                  "active"
                ]
              },
              "provider": { //该模型自己的 provider 适配信息
                "type": "object",
                "properties": {
                  "npm": {
                    "type": "string"
                  },
                  "api": {
                    "type": "string"
                  }
                },
                "additionalProperties": false
              },
              "options": { //模型级别额外选项
                "type": "object"
              },
              "headers": { //模型级别请求头
                "type": "object",
                "additionalProperties": {
                  "type": "string"
                }
              },
              "variants": { //模型变体配置
                "type": "object",
                "additionalProperties": {
                  "type": "object",
                  "properties": {
                    "disabled": {
                      "type": "boolean",
                      "description": "禁用该模型的此变体"
                    }
                  }
                },
                "description": "变体级配置"
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "McpLocalConfig": { // 一个本地 MCP 服务器应该怎么配置。
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "local"
          ],
          "description": "MCP 服务器连接类型"
        },
        "command": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "运行 MCP 服务器的命令及参数"
        },
        "environment": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          },
          "description": "运行 MCP 服务器时设置的环境变量"
        },
        "enabled": {
          "type": "boolean",
          "description": "是否在启动时启用该 MCP 服务器"
        },
        "timeout": {
          "exclusiveMinimum": 0,
          "type": "integer",
          "maximum": 9007199254740991,
          "description": "MCP 服务器请求超时时间（毫秒）。如未指定，默认 5000（5 秒）。"
        }
      },
      "required": [ //这是 schema 语法，不是你配置时写的字段。 表示 type 和 command 必须出现。
        "type",
        "command"
      ],
      "additionalProperties": false
    },
    "McpOAuthConfig": { //远程 MCP 服务如果需要 OAuth 登录认证，OAuth 参数应该怎么写。
      "type": "object",
      "properties": {
        "clientId": { //OAuth 客户端 ID。
          "type": "string",
          "description": "OAuth 客户端 ID。若未提供，将尝试动态客户端注册（RFC 7591）。"
        },
        "clientSecret": { // OAuth 客户端密钥。
          "type": "string",
          "description": "OAuth 客户端密钥（如果授权服务器要求）"
        },
        "scope": { //OAuth 授权范围。
          "type": "string",
          "description": "授权时请求的 OAuth scopes"
        },
        "redirectUri": { //OAuth 登录完成后的回调地址。
          "type": "string",
          "description": "OAuth 回调地址（默认：http://127.0.0.1:19876/mcp/oauth/callback）"
        }
        //token 会存到本机这个文件里：  ~/.local/share/opencode/mcp-auth.json
      },
      "additionalProperties": false
    },
    "McpRemoteConfig": { //一个远程 MCP 服务器应该怎么配置。
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "remote"
          ],
          "description": "MCP 服务器连接类型"
        },
        "url": {
          "type": "string",
          "description": "远程 MCP 服务器的 URL"
        },
        "enabled": {
          "type": "boolean",
          "description": "是否在启动时启用该 MCP 服务器"
        },
        "headers": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          },
          "description": "请求时要发送的请求头"
        },
        "oauth": {
          "anyOf": [
            {
              "$ref": "#/$defs/McpOAuthConfig"
            },
            {
              "type": "boolean",
              "enum": [
                false
              ]
            }
          ],
          "description": "MCP 服务器的 OAuth 认证配置。设为 false 可禁用 OAuth 自动检测。"
        },
        "timeout": {
          "exclusiveMinimum": 0,
          "type": "integer",
          "maximum": 9007199254740991,
          "description": "MCP 服务器请求超时时间（毫秒）。如未指定，默认 5000（5 秒）。"
        }
      },
      "required": [ //这是 schema 语法，不是你配置时写的字段。 表示 type 和 url 必须出现。
        "type",
        "url"
      ],
      "additionalProperties": false
    },
    "LayoutConfig": { //以前可能可以通过 layout 控制界面布局,现在 OpenCode 总是使用 stretch 布局基本不用配置它
      "type": "string",
      "enum": [
        "auto",
        "stretch"
      ]
    },
    "ImageAttachmentConfig": { //图片附件在发送给模型前应该怎么处理。
      "type": "object",
      "properties": {
        "auto_resize": {
          "type": "boolean",
          "description": "当图片超过配置限制时，在发送给模型前自动缩放（默认：true）"
        },
        "max_width": {
          "exclusiveMinimum": 0,
          "type": "integer",
          "maximum": 9007199254740991,
          "description": "图片在缩放或拒绝附加前允许的最大宽度（默认：2000）"
        },
        "max_height": {
          "exclusiveMinimum": 0,
          "type": "integer",
          "maximum": 9007199254740991,
          "description": "图片在缩放或拒绝附加前允许的最大高度（默认：2000）"
        },
        "max_base64_bytes": {
          "exclusiveMinimum": 0,
          "type": "integer",
          "maximum": 9007199254740991,
          "description": "图片附件允许的最大 base64 负载字节数（默认：4718592）"
        }
      },
      "additionalProperties": false
    },
    "AttachmentConfig": { //整个附件处理配置应该怎么写。
      "type": "object",
      "properties": {
        "image": {
          "$ref": "#/$defs/ImageAttachmentConfig",
          "description": "图片附件配置"
        }
      },
      "additionalProperties": false
    },
    "Config": { //是最外层的“总装配规则”。
      "type": "object",
      "properties": { //是 JSON Schema 的语法字段，意思是：当某个值是对象时，这个对象里面允许/定义哪些属性，以及每个属性的值应该是什么格式。
        "$schema": {
          "type": "string",
          "description": "用于配置校验的 JSON Schema 引用"
        },
        "shell": { //终端和 bash 工具默认使用的 shell
          "type": "string",
          "description": "终端和 bash 工具默认使用的 shell"
        },
        "logLevel": { //日志级别。日志文件中打印的信息繁简程度
          "$ref": "#/$defs/LogLevel",
          "description": "日志级别"
        },
        "server": { //用于 opencode serve 和 web 命令的服务器配置
          "$ref": "#/$defs/ServerConfig",
          "description": "用于 opencode serve 和 web 命令的服务器配置"
        },
        "command": { //你自己定义 OpenCode 命令的地方。
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "template": { //命令执行时真正发送给 LLM 的 prompt。
                "type": "string"
              },
              "description": { //它会显示在 TUI 里，帮助你看到这个命令是干什么的。
                "type": "string"
              },
              "agent": { //指定这个命令由哪个 agent 执行。
                "type": "string"
              },
              "model": { //指定这个命令单独使用哪个模型，覆盖默认模型。
                "type": "string",
                "$ref": "https://models.dev/model-schema.json#/$defs/Model"
              },
              "subtask": { //布尔值，控制这个命令是否作为子任务执行。
                "type": "boolean"
              }
            },
            "required": [
              "template"
            ],
            "additionalProperties": false
          },
          "description": "命令配置，见 https://opencode.ai/docs/commands"
        },
        "skills": { //配置额外的 Agent Skills 来源。Skill 是可复用的 SKILL.md 指令，OpenCode 会按需让 agent 加载。
          "type": "object",
          "properties": {
            "paths": { //额外的本地 skill 目录路径。用于让 OpenCode 扫描默认目录之外的技能目录。
              "type": "array",
              "items": {
                "type": "string" //每一项都是一个目录路径字符串，例如 "./my-skills" 或 "~/opencode-skills"。
              },
              "description": "额外的技能目录路径"
            },
            "urls": { //额外的远程 skill 来源地址。OpenCode 会从这些 URL 拉取可用技能列表。
              "type": "array",
              "items": {
                "type": "string" //每一项都是一个 URL 字符串，例如 "https://example.com/.well-known/skills/"。
              },
              "description": "拉取技能的 URL（例如 https://example.com/.well-known/skills/）"
            }
          },
          "additionalProperties": false, //skills 里面只能写 paths 和 urls，不能写其他字段。
          "description": "附加技能目录路径配置"
        },
        "reference": { // 是 OpenCode 配置里的一个顶层字段，用来定义可复用的外部参考资料别名。
          // - 一个 Git 仓库
          // - 一个本地目录
          // - 一个字符串形式的引用
          "$ref": "#/$defs/ReferenceConfig",
          "description": "具名的 Git 或本地目录引用，可通过 @alias 或 @alias/path 提及"
        },
        "watcher": { //文件监听器配置。用于控制 OpenCode 监听文件变化时要忽略哪些路径。
          "type": "object",
          "properties": {
            "ignore": { //忽略规则列表。模式使用 glob 语法，例如 "node_modules/**"、"dist/**"、".git/**"。
              "type": "array",
              "items": {
                "type": "string" //每一项都是一个 glob 忽略模式字符串。
              }
            }
          },
          "additionalProperties": false //watcher 里面只能写 ignore，不能写其他字段。
        },
        "snapshot": { //快照追踪开关。OpenCode 用快照记录 agent 操作期间的文件变化，让会话内的 undo/revert 能回滚文件改动。
          "type": "boolean",
          "description": "启用或禁用快照追踪。为 false 时不会记录文件系统快照，undo/revert 也无法撤销或重做文件变更。默认 true。" //设为 false 可减少大仓库或多 submodule 项目的索引开销和磁盘占用，但 UI 里不能回滚 agent 改过的文件。
        },
        "plugin": { //插件配置。用于从 npm 加载 OpenCode 插件；本地插件通常放在 .opencode/plugins/ 或 ~/.config/opencode/plugins/ 自动加载。
          "type": "array",
          "items": { //plugin 数组里的每一项代表一个插件。
            "anyOf": [
              {
                "type": "string" //简单写法：只写 npm 包名，例如 "opencode-wakatime" 或 "@my-org/custom-plugin"。
              },
              {
                "type": "array", //带配置写法：用二元数组表示 [插件包名, 插件配置对象]。
                "prefixItems": [ //数组第 1 项必须是插件包名字符串，第 2 项必须是传给插件的配置对象。
                  {
                    "type": "string" //插件 npm 包名。
                  },
                  {
                    "type": "object" //该插件自己的配置对象，具体字段由插件自己定义。
                  }
                ],
                "maxItems": 2, //带配置写法必须刚好 2 项，不能多。
                "minItems": 2 //带配置写法必须刚好 2 项，不能少。
              }
            ]
          }
        },
        "share": { //分享行为控制。决定新创建的对话是否自动分享、是否默认在 UI 里显示“分享”按钮
          "type": "string",
          "enum": [
            "manual",
            "auto",
            "disabled"
          ],
          "description": "控制分享行为：'manual' 允许手动分享，'auto' 自动分享，'disabled' 完全禁用分享"
        },
        "autoshare": { //废弃求了
          "type": "boolean",
          "description": "@deprecated 请改用 'share' 字段。自动分享新创建的会话"
        },
        "autoupdate": { //自动更新配置。控制 OpenCode 启动时是否自动下载新版本。
          "anyOf": [
            {
              "type": "boolean" //true 表示自动更新；false 表示禁用自动更新。
            },
            {
              "type": "string",
              "enum": [
                "notify" //只显示更新通知，不自动下载安装。
              ]
            }
          ],
          "description": "自动更新到最新版本。设为 true 自动更新，false 禁用，或 'notify' 仅显示更新通知" //如果通过 Homebrew 等包管理器安装，notify 模式可能不适用。
        },
        "disabled_providers": { //禁用自动加载的 provider。即使环境变量或 /connect 已配置凭据，被禁用的 provider 也不会加载。
          "type": "array", //provider 在 OpenCode 里指的是模型服务提供方
          "items": {
            "type": "string" //每一项是 provider ID，例如 "openai"、"gemini"。
          },
          "description": "禁用那些会被自动加载的 provider" //优先级高于 enabled_providers；被禁用后，该 provider 的模型不会出现在模型选择列表。
        },
        "enabled_providers": { // provider 白名单。设置后只启用这里列出的 provider，其他 provider 会被忽略。
          "type": "array", //provider 在 OpenCode 里指的是模型服务提供方
          "items": {
            "type": "string" //每一项是允许启用的 provider ID。
          },
          "description": "设置后，仅启用这些 provider，其他 provider 会被忽略"
        },
        "model": { //默认主模型。OpenCode 主要对话、agent 执行任务时默认使用这个模型。
          "type": "string",
          "description": "使用的模型，格式为 provider/model，例如 anthropic/claude-2", //格式通常是 "provider/model"，例如 "anthropic/claude-sonnet-4-5"。
          "$ref": "https://models.dev/model-schema.json#/$defs/Model"
        },
        "small_model": { //默认小模型。用于标题生成等轻量任务，通常可以配置成更便宜、更快的模型。
          "type": "string",
          "description": "用于标题生成等任务的小模型，格式为 provider/model", //如果不配置，OpenCode 会尝试使用同 provider 下更便宜的模型；没有可用小模型时回退到主 model。
          "$ref": "https://models.dev/model-schema.json#/$defs/Model"
        },
        "default_agent": { //默认 agent。没有明确指定 agent 时，OpenCode 使用这个 agent 处理任务。
          "type": "string",
          "description": "未显式指定时使用的默认 agent。必须是 primary agent。若未设置或无效，则回退到 'build'。" //可以是内置 "build"、"plan"，也可以是你自定义的 primary agent；不能是 subagent。
        },
        "username": { //自定义会话显示用户名。用于替代系统用户名显示在对话里。
          "type": "string",
          "description": "会话中显示的自定义用户名，替代系统用户名"
        },
        "mode": { //旧版 agent 配置字段，已废弃。现在应该使用 agent 字段。
          "type": "object",
          "properties": {
            "build": { //旧版 build agent 配置，结构仍然按 AgentConfig。
              "$ref": "#/$defs/AgentConfig"
            },
            "plan": { //旧版 plan agent 配置，结构仍然按 AgentConfig。
              "$ref": "#/$defs/AgentConfig"
            }
          },
          "additionalProperties": { //旧版也允许配置其他 agent 名称，每个值都必须符合 AgentConfig。
            "$ref": "#/$defs/AgentConfig"
          },
          "description": "@deprecated 请改用 `agent` 字段"
        },
        "agent": { //Agent 配置入口。用于配置内置 agent 或自定义 agent 的模型、提示词、权限、模式等。
          "type": "object",
          "properties": {
            "plan": { //内置 plan agent 配置，通常用于规划和只读分析。
              "$ref": "#/$defs/AgentConfig"
            },
            "build": { //内置 build agent 配置，通常用于实际修改代码和执行任务。
              "$ref": "#/$defs/AgentConfig"
            },
            "general": { //内置 general subagent 配置，通常用于通用辅助任务。
              "$ref": "#/$defs/AgentConfig"
            },
            "explore": { //内置 explore subagent 配置，通常用于代码库探索和查找信息。
              "$ref": "#/$defs/AgentConfig"
            },
            "scout": { //内置 scout agent 配置，通常用于参考资料、仓库或外部上下文检查。
              "$ref": "#/$defs/AgentConfig"
            },
            "title": { //内置 title agent 配置，通常用于生成会话标题等轻量任务。
              "$ref": "#/$defs/AgentConfig"
            },
            "summary": { //内置 summary agent 配置，通常用于总结会话或上下文。
              "$ref": "#/$defs/AgentConfig"
            },
            "compaction": { //内置 compaction agent 配置，通常用于上下文压缩。
              "$ref": "#/$defs/AgentConfig"
            }
          },
          "additionalProperties": { //允许自定义其他 agent 名称，每个 agent 的配置都必须符合 AgentConfig。
            "$ref": "#/$defs/AgentConfig"
          },
          "description": "Agent 配置，见 https://opencode.ai/docs/agents"
        },
        "provider": { //Provider 配置入口。用于配置模型服务商、连接参数，以及该 provider 下的模型覆盖或补充。
          "type": "object",
          "additionalProperties": { //provider 的键名是 provider ID；每个 provider 对象都必须符合 ProviderConfig。
            "$ref": "#/$defs/ProviderConfig"
          },
          "description": "自定义 provider 配置及模型覆盖"
        },
        "mcp": { //MCP 服务器配置入口。用于把外部工具、数据源或服务接入 OpenCode。
          "type": "object",
          "additionalProperties": { //mcp 的键名是服务器名称，例如 "github"、"sentry"、"jira"；每个值是一台 MCP 服务器配置。
            "anyOf": [
              {
                "anyOf": [ //完整服务器配置：可以是本地 MCP，也可以是远程 MCP。
                  {
                    "$ref": "#/$defs/McpLocalConfig" //本地 MCP：通过 command 在本机启动。
                  },
                  {
                    "$ref": "#/$defs/McpRemoteConfig" //远程 MCP：通过 url 连接远程服务器。
                  }
                ]
              },
              {
                "type": "object", //简写配置：只覆盖 enabled 开关，常用于启用或禁用远程组织配置里的 MCP。
                "properties": {
                  "enabled": { //是否启用这个 MCP 服务器。
                    "type": "boolean"
                  }
                },
                "required": [ //简写配置里 enabled 必填。
                  "enabled"
                ],
                "additionalProperties": false //简写配置只能写 enabled。
              }
            ]
          },
          "description": "MCP（Model Context Protocol）服务器配置"
        },
        "formatter": { //格式化器配置。用于让 OpenCode 在修改文件后调用格式化工具，例如 prettier、gofmt、black 等。
          "anyOf": [
            {
              "type": "boolean" //false 或省略表示禁用；true 表示启用内置格式化器配置。
            },
            {
              "type": "object",
              "additionalProperties": { //对象写法：键名是格式化器名称；值是该格式化器的配置。
                "type": "object",
                "properties": {
                  "disabled": { //是否禁用这个格式化器。常用于关闭某个内置格式化器。
                    "type": "boolean"
                  },
                  "command": { //运行格式化器的命令和参数，例如 ["npx", "prettier", "--write", "$FILE"]。
                    "type": "array",
                    "items": {
                      "type": "string" //命令数组里的每一项都是字符串参数。
                    }
                  },
                  "environment": { //运行格式化命令时附加的环境变量。
                    "type": "object",
                    "additionalProperties": {
                      "type": "string" //环境变量的值必须是字符串。
                    }
                  },
                  "extensions": { //该格式化器处理的文件扩展名列表，例如 [".js", ".ts", ".tsx"]。
                    "type": "array",
                    "items": {
                      "type": "string" //每一项是一个文件扩展名字符串。
                    }
                  }
                },
                "additionalProperties": false //单个 formatter 配置里只能写 disabled、command、environment、extensions。
              }
            }
          ],
          "description": "启用或配置格式化器。省略或设为 false 表示禁用，true 表示启用内置配置，对象表示在启用内置配置的基础上进行覆盖。"
        },
        "lsp": { //LSP 服务器配置。用于接入语言服务器，提供诊断、跳转定义、符号等代码智能能力。
          "anyOf": [
            {
              "type": "boolean" //false 或省略表示禁用；true 表示启用内置 LSP 配置。
            },
            {
              "type": "object",
              "additionalProperties": { //对象写法：键名是 LSP 服务器名称；值是该 LSP 的禁用配置或自定义启动配置。
                "anyOf": [
                  {
                    "type": "object", //只禁用某个内置 LSP 的简写配置。
                    "properties": {
                      "disabled": { //这里固定只能写 true，表示禁用该 LSP。
                        "type": "boolean",
                        "enum": [
                          true
                        ]
                      }
                    },
                    "required": [ //禁用简写必须包含 disabled。
                      "disabled"
                    ],
                    "additionalProperties": false //禁用简写只能写 disabled。
                  },
                  {
                    "type": "object", //自定义 LSP 启动配置。
                    "properties": {
                      "command": { //启动语言服务器的命令和参数，例如 ["typescript-language-server", "--stdio"]。
                        "type": "array",
                        "items": {
                          "type": "string" //命令数组里的每一项都是字符串参数。
                        }
                      },
                      "extensions": { //这个 LSP 负责的文件扩展名列表，例如 [".ts", ".tsx"]。
                        "type": "array",
                        "items": {
                          "type": "string" //每一项是一个文件扩展名字符串。
                        }
                      },
                      "disabled": { //是否禁用这个自定义 LSP 配置。
                        "type": "boolean"
                      },
                      "env": { //启动 LSP 时附加的环境变量。
                        "type": "object",
                        "additionalProperties": {
                          "type": "string" //环境变量的值必须是字符串。
                        }
                      },
                      "initialization": { //发送给语言服务器的初始化选项，具体结构由对应 LSP 决定。
                        "type": "object"
                      }
                    },
                    "required": [ //自定义 LSP 配置里 command 必填。
                      "command"
                    ],
                    "additionalProperties": false //自定义 LSP 配置里只能写 command、extensions、disabled、env、initialization。
                  }
                ]
              }
            }
          ],
          "description": "启用或配置 LSP 服务器。省略或设为 false 表示禁用，true 表示启用内置配置，对象表示在启用内置配置的基础上进行覆盖。"
        },
        "instructions": { //额外 instruction/rules 文件列表。用于给模型加载项目规则、贡献指南、编码规范等上下文。
          "type": "array",
          "items": {
            "type": "string" //每一项是文件路径或 glob 模式，例如 "CONTRIBUTING.md"、"docs/guidelines.md"、".cursor/rules/*.md"。
          },
          "description": "额外引入的 instruction 文件或匹配模式"
        },
        "layout": { // 废弃求了
          "$ref": "#/$defs/LayoutConfig",
          "description": "@deprecated 现在始终使用 stretch 布局"
        },
        "permission": { //权限配置。
          "$ref": "#/$defs/PermissionConfig"
        },
        "tools": { //工具使用配置。键名是工具名称，值是 boolean（true=允许，false=禁用）。
          "type": "object",
          "additionalProperties": {
            "type": "boolean"
          }
        },
        "attachment": { //附件处理配置，包括图片尺寸限制和缩放行为。
          "$ref": "#/$defs/AttachmentConfig",
          "description": "附件处理配置，包括图片尺寸限制和缩放行为"
        },
        "enterprise": { //企业版配置。用于组织/企业部署场景，通常和集中配置、SSO、内部 AI gateway 等企业能力相关。
          "type": "object",
          "properties": {
            "url": { //企业版服务地址。用于指向组织提供的 OpenCode Enterprise 端点。
              "type": "string",
              "description": "企业版 URL"
            }
          },
          "additionalProperties": false //enterprise 里面只能写 url，不能写其他字段。
        },
        "tool_output": { //工具输出截断配置。用于控制 bash、读取文件、搜索等工具返回内容过长时的处理方式。
          "type": "object",
          "properties": {
            "max_lines": { //工具输出最多直接返回多少行；超过后完整输出会写入磁盘，只返回预览。
              "exclusiveMinimum": 0, //必须大于 0。
              "type": "integer",
              "maximum": 9007199254740991,
              "description": "工具输出在被截断并写入磁盘前允许的最大行数（默认：2000）"
            },
            "max_bytes": { //工具输出最多直接返回多少字节；超过后完整输出会写入磁盘，只返回预览。
              "exclusiveMinimum": 0, //必须大于 0。
              "type": "integer",
              "maximum": 9007199254740991,
              "description": "工具输出在被截断并写入磁盘前允许的最大字节数（默认：51200）"
            }
          },
          "additionalProperties": false, //tool_output 里面只能写 max_lines 和 max_bytes。
          "description": "工具输出截断阈值。超过任一限制时，完整文本会写入截断目录，并返回一段预览。"
        },
        "compaction": { //上下文压缩配置。用于在会话上下文接近模型窗口上限时压缩旧内容，保留继续工作的关键信息。
          "type": "object",
          "properties": {
            "auto": { //是否在上下文满时自动压缩。
              "type": "boolean",
              "description": "当上下文已满时自动执行压缩（默认：true）"
            },
            "prune": { //是否清理/裁剪旧工具输出，以减少 token 占用。
              "type": "boolean",
              "description": "启用旧工具输出清理（默认：true）"
            },
            "tail_turns": { //压缩时保留最近多少轮用户对话及其后的 assistant/tool 响应原文。
              "minimum": 0, //可以为 0。
              "type": "integer",
              "maximum": 9007199254740991,
              "description": "压缩时按原文保留的最近用户轮次数量，包含其后的 assistant/tool 响应（默认：2）"
            },
            "preserve_recent_tokens": { //压缩后额外按原文保留最近内容的最大 token 数。
              "minimum": 0, //可以为 0。
              "type": "integer",
              "maximum": 9007199254740991,
              "description": "压缩后按原文保留的最近轮次最大 token 数"
            },
            "reserved": { //为压缩过程预留的 token 缓冲，避免压缩请求本身也挤爆上下文窗口。
              "minimum": 0, //可以为 0。
              "type": "integer",
              "maximum": 9007199254740991,
              "description": "为压缩预留的 token 缓冲区，用于避免压缩过程中窗口溢出"
            }
          },
          "additionalProperties": false //compaction 里面只能写 auto、prune、tail_turns、preserve_recent_tokens、reserved。
        },
        "experimental": { //实验性配置。这里的开关可能不稳定，升级后行为或字段可能变化。
          "type": "object",
          "properties": {
            "disable_paste_summary": { //是否禁用粘贴内容摘要功能。
              "type": "boolean"
            },
            "batch_tool": { //是否启用 batch tool。  批处理工具 一次性发起一组工具调用
              "type": "boolean",
              "description": "启用 batch tool"
            },
            //OpenTelemetry 是一个可观测性标准，用来收集程序运行时的追踪、指标、日志等数据。
            // span 是一次 trace 里的一个小片段。可以理解成：
            "openTelemetry": { //是否为 AI SDK 调用启用 OpenTelemetry 追踪 spans。
              "type": "boolean",
              "description": "为 AI SDK 调用启用 OpenTelemetry spans（使用 'experimental_telemetry' 标志）"
            },
            "primary_tools": { // 指定哪些工具只对 primary agents 可用，subagent 不可用。
              "type": "array",
              "items": {
                "type": "string" //每一项是工具名称。
              },
              "description": "仅对 primary agents 可用的工具"
            },
            "continue_loop_on_deny": { //工具调用被拒绝后，是否继续 agent 循环而不是直接停下。
              "type": "boolean",
              "description": "当工具调用被拒绝时继续 agent 循环"
            },
            "mcp_timeout": { //MCP 请求超时时间，单位毫秒。
              "exclusiveMinimum": 0, //必须大于 0。
              "type": "integer",
              "maximum": 9007199254740991,
              "description": "模型上下文协议（MCP）请求的超时时间（毫秒）"
            }
          },
          "additionalProperties": false //experimental 里面只能写这里列出的实验性字段。
        }
      },
      "additionalProperties": false // addititonal : 附加的 properties 属性
    }
  },
  "allowComments": true, //允许配置文件里写注释。也就是支持 JSONC 里的 // 行注释和 /* 块注释 */，普通 JSON 标准本身不允许注释。
  "allowTrailingCommas": true //允许对象或数组最后一项后面保留尾随逗号，方便增删配置项。
}
